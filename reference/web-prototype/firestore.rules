rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "jonathanisreed@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // --- Users ---
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }
    
    // --- Products ---
    match /products/{productId} {
      // Allow anyone to see and contribute to products for the shared database
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }
    
    // --- Ingredients ---
    match /ingredients/{ingredientId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }
    
    // --- Ingredient Mappings ---
    match /ingredientMappings/{mappingId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }
    
    // --- Leaderboard ---
    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }
    
    // --- Facts ---
    match /facts/{factId} {
      // Allow anyone to read facts for the home screen
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // --- Connection Test ---
    match /test/connection {
      allow read: if true;
    }

    // --- Fallback ---
    match /{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
